#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
GitHub Hacker - Entry point script

Usage:
    ./github-hacker [command]
    python github-hacker [command]
"""
import sys
import os

# Get the directory where this script is located
SCRIPT_DIR = os.path.dirname(os.path.realpath(__file__))
VENV_PYTHON = os.path.join(SCRIPT_DIR, "venv", "bin", "python")

# If virtual environment exists, use it
if os.path.exists(VENV_PYTHON):
    os.execv(VENV_PYTHON, [VENV_PYTHON, "-m", "githubhacker.cli"] + sys.argv[1:])

# Otherwise use system python with the module
from githubhacker.cli import main

if __name__ == "__main__":
    main()
